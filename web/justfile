# Frontend (React/Vite) recipes

# Start the Vite dev server alone. Assumes the backend is already running.
dev:
    bun run dev

# Production build
build:
    bun run build

# Lint, typecheck, and verify formatting
check:
    bun run check

# Typecheck
typecheck:
    bun run typecheck

# Format frontend sources
fmt:
    bun run format

# Check frontend formatting
fmt-check:
    bun run format:check

# Lint with auto-fix, then format
lint-fix:
    bun run lint --fix
    bun run format

# Preview production build
preview:
    bun run preview

# Install dependencies
install:
    bun install
