# Frontend (React/Vite) recipes

# Start the Vite dev server alone. Assumes the backend is already running.
dev:
    bun run dev

# Production build
build:
    bun run build

# Lint
check:
    bun run lint

# Lint with auto-fix
lint-fix:
    bun run lint --fix

# Preview production build
preview:
    bun run preview

# Install dependencies
install:
    bun install
