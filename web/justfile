# Frontend (React/Vite) recipes

# Start the full dev stack (stalwart + daemon + vite) in a zellij session.
dev:
    bash ../dev/zellij/launch.sh web

# Start the vite dev server alone. Assumes the backend is already running.
dev-frontend:
    bun run dev

# Production build
build:
    bun run build

# Lint
check:
    bun run lint

# Lint with auto-fix
lint-fix:
    bun run lint --fix

# Preview production build
preview:
    bun run preview

# Install dependencies
install:
    bun install
