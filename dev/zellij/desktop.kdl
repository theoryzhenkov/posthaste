// Zellij layout for `just desktop dev`: full stack for the Tauri shell.
// Tauri embeds posthaste-daemon and runs vite via `beforeDevCommand`, so only
// stalwart + seed need to orbit around `cargo tauri dev`.

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="posthaste-desktop" focus=true {
        pane split_direction="Vertical" {
            pane name="tauri" command="cargo" size="60%" cwd="src-tauri" {
                args "tauri" "dev"
            }
            pane split_direction="Horizontal" size="40%" {
                pane name="stalwart" command="stalwart" {
                    args "-c" "dev/stalwart/config.toml"
                }
                pane name="seed" command="bash" {
                    args "dev/stalwart/seed.sh"
                }
            }
        }
    }
}
