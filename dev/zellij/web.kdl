// Zellij layout for `just web dev`: full stack for browser-based dev.
// Stalwart + seed (oneshot) + posthaste-daemon + vite, in one session.
// All panes inherit env from the launching shell — the root justfile sets
// POSTHASTE_CONFIG_ROOT, POSTHASTE_STATE_ROOT, POSTHASTE_BOOTSTRAP_PATH,
// POSTHASTE_STALWART_* before invoking zellij.

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="posthaste-dev" focus=true {
        pane split_direction="Vertical" {
            pane split_direction="Horizontal" size="60%" {
                pane name="daemon" command="cargo" {
                    args "run" "--bin" "posthaste-daemon"
                }
                pane name="vite" command="bun" cwd="web" {
                    args "run" "dev"
                }
            }
            pane split_direction="Horizontal" size="40%" {
                pane name="stalwart" command="stalwart" {
                    args "-c" "dev/stalwart/config.toml"
                }
                pane name="seed" command="bash" {
                    args "dev/stalwart/seed.sh"
                }
            }
        }
    }
}
