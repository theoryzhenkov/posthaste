{
  "productName": "PostHaste",
  "version": "0.1.0",
  "identifier": "com.posthaste.mail",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "cd ../web && bun run dev -- --host 127.0.0.1 --port 5173 --strictPort",
    "beforeBuildCommand": "cd ../web && bun run build"
  },
  "app": {
    "windows": [],
    "security": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
