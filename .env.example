# Project environment variables.
# Copy to .env via: just setup

# Server
POSTHASTE_CONFIG_ROOT=~/.config/posthaste
POSTHASTE_STATE_ROOT=~/.local/share/posthaste
POSTHASTE_BOOTSTRAP_PATH=~/.config/posthaste/bootstrap.toml
POSTHASTE_BIND=127.0.0.1:3001
POSTHASTE_CORS_ORIGIN=http://localhost:5173
POSTHASTE_POLL_INTERVAL=60
POSTHASTE_LOG_LEVEL=info

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:3001/v1
